<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="RootPage"
    x:Class="AutoLock_WinUI.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AutoLock.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        MaxWidth="1080"
        Width="{Binding ActualWidth, ElementName=RootPage}"
        Padding="36,28,36,40"
        HorizontalAlignment="Center"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                x:Name="PageTitleText"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="历史记录" />
            <TextBlock
                x:Name="PageSubtitleText"
                Style="{StaticResource PageSubtitleTextBlockStyle}"
                Text="查看最近的绑定、扫描、监控和锁定事件" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="16"
            Style="{StaticResource SettingsCardStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox
                    x:Name="FilterBox"
                    Header="事件类型"
                    SelectionChanged="FilterBox_SelectionChanged">
                    <ComboBoxItem x:Name="FilterAllItem" Content="全部事件" Tag="All" />
                    <ComboBoxItem x:Name="FilterMonitorItem" Content="监控" Tag="Monitor" />
                    <ComboBoxItem x:Name="FilterLockItem" Content="锁定" Tag="Lock" />
                    <ComboBoxItem x:Name="FilterBindingItem" Content="绑定" Tag="Binding" />
                    <ComboBoxItem x:Name="FilterScanItem" Content="扫描" Tag="Scan" />
                    <ComboBoxItem x:Name="FilterSessionItem" Content="会话" Tag="Session" />
                    <ComboBoxItem x:Name="FilterNotificationItem" Content="通知" Tag="Notification" />
                </ComboBox>
                <TextBlock
                    x:Name="HistoryCountText"
                    Grid.Column="1"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Bottom" />
                <Button
                    x:Name="RefreshButton"
                    Grid.Column="2"
                    Click="RefreshButton_Click"
                    VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE895;" />
                        <TextBlock x:Name="RefreshButtonText" Text="刷新" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ClearHistoryButton"
                    Grid.Column="3"
                    Click="ClearHistoryButton_Click"
                    VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Glyph="&#xE74D;" />
                        <TextBlock x:Name="ClearHistoryButtonText" Text="清空" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="2"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational"
            Title="就绪" />

        <Border
            Grid.Row="3"
            MinHeight="420"
            Style="{StaticResource SettingsCardStyle}">
            <Grid>
                <ListView
                    x:Name="HistoryList"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="IsTabStop" Value="False" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:HistoryLogEntry">
                            <Border
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                                <Grid Padding="18,14" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="142" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        FontSize="13"
                                        Text="{x:Bind TimestampLocal}"
                                        VerticalAlignment="Top" />
                                    <Border
                                        Grid.Column="1"
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Kind}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" Spacing="5">
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{x:Bind DisplayTitle}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                FontFamily="Consolas"
                                                FontSize="12"
                                                Text="{x:Bind DeviceIdentityDisplay}" />
                                        </Grid>
                                        <TextBlock
                                            Style="{StaticResource SettingRowDescriptionTextBlockStyle}"
                                            Text="{x:Bind DisplayMessage}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    x:Name="EmptyHistoryPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10"
                    Visibility="Collapsed">
                    <FontIcon
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        FontSize="32"
                        Glyph="&#xE81C;" />
                    <TextBlock
                        x:Name="EmptyHistoryTitleText"
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="没有历史记录" />
                    <TextBlock
                        x:Name="EmptyHistoryHelpText"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SettingRowDescriptionTextBlockStyle}"
                        Text="监控和锁定事件会显示在这里。" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
