<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="RootPage"
    x:Class="AutoLock_WinUI.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalContentAlignment="Center"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="960"
            Width="{Binding ActualWidth, ElementName=RootPage}"
            Padding="36,28,36,40"
            HorizontalAlignment="Center"
            RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock
                    x:Name="PageTitleText"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="关于" />
                <TextBlock
                    x:Name="PageSubtitleText"
                    Style="{StaticResource PageSubtitleTextBlockStyle}"
                    Text="版本、数据路径和诊断信息" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Padding="24"
                Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image
                        Width="56"
                        Height="56"
                        Source="/Assets/Square44x44Logo.scale-200.png" />
                    <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="AutoLock" />
                        <TextBlock
                            x:Name="ProductSubtitleText"
                            Style="{StaticResource SettingRowDescriptionTextBlockStyle}"
                            Text="蓝牙设备离开后自动锁定 Windows" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="3" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="VersionTitleText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="版本" />
                        <TextBlock
                            x:Name="VersionValueText"
                            HorizontalAlignment="Right"
                            FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Spacing="10">
                <TextBlock
                    x:Name="DiagnosticsSectionText"
                    Style="{StaticResource SectionTitleTextBlockStyle}"
                    Text="数据与诊断" />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <Grid Padding="20,14" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DataDirTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="数据目录" />
                            <TextBlock x:Name="DataDirValueText" Grid.Column="1" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" />
                        </Grid>
                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,14" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="BindingPathTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="绑定配置" />
                            <TextBlock x:Name="BindingPathValueText" Grid.Column="1" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" />
                        </Grid>
                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,14" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SettingsPathTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="应用设置" />
                            <TextBlock x:Name="SettingsPathValueText" Grid.Column="1" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" />
                        </Grid>
                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,14" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="HistoryPathTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="历史记录" />
                            <TextBlock x:Name="HistoryPathValueText" Grid.Column="1" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" />
                        </Grid>
                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,14" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CrashLogTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="崩溃日志" />
                            <TextBlock x:Name="CrashLogValueText" Grid.Column="1" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="OpenDataDirButton"
                    Click="OpenDataDirButton_Click"
                    HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8DA;" />
                        <TextBlock x:Name="OpenDataDirButtonText" Text="打开数据目录" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
