<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="RootPage"
    x:Class="AutoLock_WinUI.Pages.ProtectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalContentAlignment="Center"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1080"
            Width="{Binding ActualWidth, ElementName=RootPage}"
            Padding="36,28,36,40"
            HorizontalAlignment="Center"
            RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock
                    x:Name="PageTitleText"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="保护" />
                <TextBlock
                    x:Name="PageSubtitleText"
                    Style="{StaticResource PageSubtitleTextBlockStyle}"
                    Text="绑定的蓝牙设备离开后自动锁定 Windows" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Padding="24"
                Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Background="{ThemeResource AccentFillColorTertiaryBrush}"
                        Style="{StaticResource IconBadgeBorderStyle}">
                        <FontIcon
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            FontSize="18"
                            Glyph="&#xE72E;" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock
                            x:Name="CurrentProtectionTitleText"
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="当前保护" />
                        <TextBlock
                            x:Name="BindingDeviceNameText"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="正在加载绑定设备" />
                        <StackPanel
                            x:Name="BindingIdentityPanel"
                            Orientation="Horizontal"
                            Spacing="10">
                            <Border
                                Padding="8,3"
                                Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon
                                        x:Name="BindingIdentityIcon"
                                        FontSize="12"
                                        Glyph="&#xE702;" />
                                    <TextBlock
                                        x:Name="BindingIdentityKindText"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="MAC" />
                                </StackPanel>
                            </Border>
                            <TextBlock
                                x:Name="BindingIdentityValueText"
                                FontFamily="Consolas"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="AA:BB:**:**:EE:FF"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{ThemeResource SystemFillColorSuccessBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="SignalText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="空闲" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        MinWidth="176"
                        Spacing="10"
                        VerticalAlignment="Center">
                        <Button
                            x:Name="StartStopButton"
                            Click="StartStopButton_Click"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="StartStopButtonIcon" Glyph="&#xE768;" />
                                <TextBlock x:Name="StartStopButtonText" Text="开始监控" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="ScanDevicesButton"
                            Click="ScanDevicesButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC50;" />
                                <TextBlock x:Name="ScanDevicesButtonText" Text="选择设备" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <InfoBar
                x:Name="StatusInfoBar"
                Grid.Row="2"
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="就绪"
                Message="已加载绑定设备，当前未开始监控。" />

            <StackPanel Grid.Row="3" Spacing="10">
                <TextBlock
                    x:Name="RulesSectionText"
                    Style="{StaticResource SectionTitleTextBlockStyle}"
                    Text="保护规则" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <Grid Padding="20,16" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                Style="{StaticResource IconBadgeBorderStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    FontSize="17"
                                    Glyph="&#xE121;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="ScanSecondsTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="扫描间隔" />
                                <TextBlock x:Name="ScanSecondsHelpText" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" Text="多久扫描一次附近设备" />
                            </StackPanel>
                            <NumberBox
                                x:Name="ScanSecondsBox"
                                Grid.Column="2"
                                Minimum="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ProtectionNumberBox_ValueChanged"
                                Value="8"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,16" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                Style="{StaticResource IconBadgeBorderStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    FontSize="17"
                                    Glyph="&#xE916;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="MissingSecondsTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="消失超时" />
                                <TextBlock x:Name="MissingSecondsHelpText" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" Text="超过这个时间没有收到目标信号后锁定 Windows。" />
                            </StackPanel>
                            <NumberBox
                                x:Name="MissingSecondsBox"
                                Grid.Column="2"
                                Minimum="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ProtectionNumberBox_ValueChanged"
                                Value="30"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,16" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                Style="{StaticResource IconBadgeBorderStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    FontSize="17"
                                    Glyph="&#xEC3F;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="MinRssiTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="最低信号" />
                                <TextBlock x:Name="MinRssiHelpText" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" Text="低于该 dBm 的广播会被视为弱信号并忽略。" />
                            </StackPanel>
                            <NumberBox
                                x:Name="MinRssiBox"
                                Grid.Column="2"
                                Maximum="0"
                                Minimum="-120"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ProtectionNumberBox_ValueChanged"
                                Value="-90"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Margin="20,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="20,16" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                Style="{StaticResource IconBadgeBorderStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    FontSize="17"
                                    Glyph="&#xE7BA;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="DryRunTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="测试模式，不锁定" />
                                <TextBlock x:Name="DryRunHelpText" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" Text="验证检测逻辑时只显示提示。" />
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="DryRunSwitch"
                                Grid.Column="2"
                                Toggled="DryRunSwitch_Toggled"
                                VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4" Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock
                        x:Name="ActionsSectionText"
                        Style="{StaticResource SectionTitleTextBlockStyle}"
                        Text="更多操作" />
                    <TextBlock
                        x:Name="ActionsHelpText"
                        Style="{StaticResource SettingRowDescriptionTextBlockStyle}"
                        Text="临时暂停、测试锁定或管理当前绑定。" />
                </StackPanel>

                <Border Padding="18" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="PauseButton"
                            Click="PauseButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE823;" />
                                <TextBlock x:Name="PauseButtonText" Text="暂停 15 分钟" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="TestLockButton"
                            Grid.Column="1"
                            Click="TestLockButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72E;" />
                                <TextBlock x:Name="TestLockButtonText" Text="测试锁定" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="ClearBindingButton"
                            Grid.Column="2"
                            Click="ClearBindingButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" />
                                <TextBlock x:Name="ClearBindingButtonText" Text="解绑当前设备" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
