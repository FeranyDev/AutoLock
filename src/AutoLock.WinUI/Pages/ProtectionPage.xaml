<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AutoLock_WinUI.Pages.ProtectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
        <Style x:Key="IconTileStyle" TargetType="Border">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1180"
            Padding="40,30,40,40"
            HorizontalAlignment="Center"
            RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    x:Name="PageTitleText"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="保护设置" />
                <TextBlock
                    x:Name="PageSubtitleText"
                    Style="{StaticResource MutedTextStyle}"
                    Text="绑定的蓝牙设备离开后自动锁定 Windows" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Padding="24"
                Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}" Style="{StaticResource IconTileStyle}">
                        <FontIcon
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            FontSize="19"
                            Glyph="&#xE72E;" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="CurrentProtectionTitleText"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="当前保护" />
                        <TextBlock
                            x:Name="BindingAddressText"
                            Style="{StaticResource MutedTextStyle}"
                            Text="正在加载绑定设备" />
                        <Border
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontSize="14"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE946;" />
                                <TextBlock
                                    x:Name="SignalText"
                                    FontWeight="SemiBold"
                                    Text="空闲"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        MinWidth="190"
                        Spacing="10"
                        VerticalAlignment="Center">
                        <Button
                            x:Name="StartStopButton"
                            Click="StartStopButton_Click"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE768;" />
                                <TextBlock x:Name="StartStopButtonText" Text="开始监控" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="ScanDevicesButton"
                            Click="ScanDevicesButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC50;" />
                                <TextBlock x:Name="ScanDevicesButtonText" Text="扫描设备" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <InfoBar
                x:Name="StatusInfoBar"
                Grid.Row="2"
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="就绪"
                Message="已加载绑定设备，当前未开始监控。" />

            <Grid Grid.Row="3" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border Padding="26" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="0">
                        <TextBlock
                            x:Name="RulesSectionText"
                            Margin="0,0,0,18"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="保护设置" />

                        <Grid Padding="0,0,0,18" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}" Style="{StaticResource IconTileStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    FontSize="18"
                                    Glyph="&#xE121;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="ScanSecondsTitleText" FontWeight="SemiBold" Text="扫描间隔" />
                                <TextBlock x:Name="ScanSecondsHelpText" Style="{StaticResource MutedTextStyle}" Text="多久扫描一次附近设备" />
                            </StackPanel>
                            <NumberBox
                                x:Name="ScanSecondsBox"
                                Grid.Column="2"
                                Minimum="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ProtectionNumberBox_ValueChanged"
                                Value="8" />
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="0,18" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" Style="{StaticResource IconTileStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    FontSize="18"
                                    Glyph="&#xE916;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="MissingSecondsTitleText" FontWeight="SemiBold" Text="消失秒数" />
                                <TextBlock x:Name="MissingSecondsHelpText" Style="{StaticResource MutedTextStyle}" Text="超过这个时间没有收到目标信号后锁定 Windows。" />
                            </StackPanel>
                            <NumberBox
                                x:Name="MissingSecondsBox"
                                Grid.Column="2"
                                Minimum="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ProtectionNumberBox_ValueChanged"
                                Value="30" />
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="0,18" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}" Style="{StaticResource IconTileStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    FontSize="18"
                                    Glyph="&#xEC3F;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="MinRssiTitleText" FontWeight="SemiBold" Text="最低信号" />
                                <TextBlock x:Name="MinRssiHelpText" Style="{StaticResource MutedTextStyle}" Text="低于该 dBm 的广播会被视为弱信号并忽略。" />
                            </StackPanel>
                            <NumberBox
                                x:Name="MinRssiBox"
                                Grid.Column="2"
                                Maximum="0"
                                Minimum="-120"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ProtectionNumberBox_ValueChanged"
                                Value="-90" />
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Padding="0,18,0,0" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" Style="{StaticResource IconTileStyle}">
                                <FontIcon
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    FontSize="18"
                                    Glyph="&#xE72E;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="DryRunTitleText" FontWeight="SemiBold" Text="测试模式，不锁定" />
                                <TextBlock x:Name="DryRunHelpText" Style="{StaticResource MutedTextStyle}" Text="验证检测逻辑时只显示提示。" />
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="DryRunSwitch"
                                Grid.Column="2"
                                Toggled="DryRunSwitch_Toggled"
                                VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="24"
                    Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            x:Name="ActionsSectionText"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="操作" />

                        <TextBlock
                            x:Name="ActionsHelpText"
                            Style="{StaticResource MutedTextStyle}"
                            Text="临时暂停、测试锁定或管理当前绑定。" />

                        <Button
                            x:Name="PauseButton"
                            Click="PauseButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE823;" />
                                <TextBlock x:Name="PauseButtonText" Text="暂停 15 分钟" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="TestLockButton"
                            Click="TestLockButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72E;" />
                                <TextBlock x:Name="TestLockButtonText" Text="测试锁定" />
                            </StackPanel>
                        </Button>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Button
                            x:Name="ClearBindingButton"
                            Click="ClearBindingButton_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" />
                                <TextBlock x:Name="ClearBindingButtonText" Text="解绑当前设备" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
