<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Name="RootPage"
    x:Class="AutoLock_WinUI.Pages.ScanDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AutoLock.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        MaxWidth="1080"
        Width="{Binding ActualWidth, ElementName=RootPage}"
        Padding="36,28,36,40"
        HorizontalAlignment="Center"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock
                    x:Name="PageTitleText"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="设备" />
                <TextBlock
                    x:Name="PageSubtitleText"
                    Style="{StaticResource PageSubtitleTextBlockStyle}"
                    Text="查找附近蓝牙设备并保存绑定信息" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="12"
                VerticalAlignment="Center">
                <TextBlock
                    x:Name="ScanDurationText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="ScanButton"
                    Click="ScanButton_Click"
                    MinWidth="112"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE71E;" />
                        <TextBlock x:Name="ScanButtonText" Text="开始扫描" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Message="可以开始扫描附近设备。"
            Severity="Informational"
            Title="就绪" />

        <Expander
            x:Name="IrkExpander"
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            IsExpanded="False">
            <Expander.Header>
                <Grid MinHeight="54" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Background="{ThemeResource AccentFillColorTertiaryBrush}"
                        Style="{StaticResource IconBadgeBorderStyle}">
                        <FontIcon
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            FontSize="17"
                            Glyph="&#xE8D7;" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                        <TextBlock x:Name="IrkSectionTitleText" Style="{StaticResource SettingRowTitleTextBlockStyle}" Text="高级识别（IRK）" />
                        <TextBlock x:Name="IrkSectionHelpText" Style="{StaticResource SettingRowDescriptionTextBlockStyle}" Text="仅用于采用随机蓝牙地址的设备，普通设备可以跳过。" />
                    </StackPanel>
                </Grid>
            </Expander.Header>
            <Grid Padding="4,8,4,18" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox
                    x:Name="IrkBox"
                    PlaceholderText="32 位十六进制值" />
                <Button
                    x:Name="IrkAssistantButton"
                    Grid.Column="1"
                    Click="IrkAssistantButton_Click"
                    MinWidth="120">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE897;" />
                        <TextBlock x:Name="IrkAssistantButtonText" Text="获取 IRK" />
                    </StackPanel>
                </Button>
            </Grid>
        </Expander>

        <Border
            Grid.Row="3"
            MinHeight="390"
            Style="{StaticResource SettingsCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Padding="20,16" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            FontSize="18"
                            Glyph="&#xEC50;" />
                        <TextBlock
                            x:Name="DevicesSectionText"
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="附近设备" />
                    </StackPanel>
                    <TextBlock
                        x:Name="BleText"
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="BLE"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="BindSelectedButton"
                        Grid.Column="2"
                        Click="BindSelectedButton_Click"
                        IsEnabled="False"
                        MinWidth="144">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" />
                            <TextBlock x:Name="BindSelectedButtonText" Text="绑定选中设备" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ListView
                    x:Name="DevicesList"
                    Grid.Row="1"
                    SelectionChanged="DevicesList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.Header>
                        <Grid Padding="18,10" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="94" />
                                <ColumnDefinition Width="126" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="AddressColumnText" FontWeight="SemiBold" Text="地址" />
                            <TextBlock x:Name="RssiColumnText" Grid.Column="1" FontWeight="SemiBold" Text="信号" />
                            <TextBlock x:Name="SeenColumnText" Grid.Column="2" FontWeight="SemiBold" Text="次数" />
                            <TextBlock x:Name="AppleDataColumnText" Grid.Column="3" FontWeight="SemiBold" Text="厂商数据" />
                            <TextBlock x:Name="IrkMatchColumnText" Grid.Column="4" FontWeight="SemiBold" Text="IRK 匹配" />
                            <TextBlock x:Name="LastSeenColumnText" Grid.Column="5" FontWeight="SemiBold" Text="最后出现" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:DeviceSighting">
                            <Grid Padding="18,11" ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="94" />
                                    <ColumnDefinition Width="126" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontFamily="Consolas" Text="{x:Bind DisplayAddress}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Rssi}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind SeenCount}" />
                                <CheckBox
                                    Grid.Column="3"
                                    HorizontalAlignment="Left"
                                    IsChecked="{x:Bind HasAppleManufacturerData, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <CheckBox
                                    Grid.Column="4"
                                    HorizontalAlignment="Left"
                                    IsChecked="{x:Bind ResolvesWithIrk, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <TextBlock Grid.Column="5" Text="{x:Bind LastSeenLocal, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
