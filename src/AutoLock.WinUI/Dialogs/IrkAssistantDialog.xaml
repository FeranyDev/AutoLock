<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="AutoLock_WinUI.Dialogs.IrkAssistantDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="760">

    <Grid Width="760" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabView
            x:Name="MethodTabs"
            IsAddTabButtonVisible="False"
            TabWidthMode="Equal">
            <TabViewItem x:Name="WindowsTab" IsClosable="False">
                <ScrollViewer MaxHeight="470" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="4,12,4,16" Spacing="14">
                        <Border
                            Padding="16"
                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                            CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE946;"
                                    FontSize="16" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock
                                        x:Name="WindowsGuideTitleText"
                                        FontWeight="SemiBold"
                                        IsTextSelectionEnabled="True" />
                                    <TextBlock
                                        x:Name="WindowsGuideText"
                                        IsTextSelectionEnabled="True"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="SystemCommandBox"
                                Header="SYSTEM 命令"
                                IsReadOnly="True"
                                Text="psexec -s -i regedit" />
                            <TextBox
                                x:Name="RegistryPathBox"
                                Grid.Column="1"
                                Header="注册表路径"
                                IsReadOnly="True"
                                Text="HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Services\BTHPORT\Parameters\Keys" />
                        </Grid>

                        <TextBox
                            x:Name="BluetoothAddressBox"
                            Header="设备蓝牙地址"
                            PlaceholderText="AA:BB:CC:DD:EE:FF" />

                        <Button Click="ImportRegistryButton_Click" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" />
                                <TextBlock x:Name="ImportRegistryButtonText" Text="导入注册表文件" />
                            </StackPanel>
                        </Button>

                        <InfoBar
                            x:Name="WindowsResultInfo"
                            IsClosable="False"
                            IsOpen="False">
                            <TextBlock
                                x:Name="WindowsResultText"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap" />
                        </InfoBar>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem x:Name="MacTab" IsClosable="False">
                <ScrollViewer MaxHeight="470" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="4,12,4,16" Spacing="14">
                        <Border
                            Padding="16"
                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                            CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE946;"
                                    FontSize="16" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock
                                        x:Name="MacGuideTitleText"
                                        FontWeight="SemiBold"
                                        IsTextSelectionEnabled="True" />
                                    <TextBlock
                                        x:Name="MacGuideText"
                                        IsTextSelectionEnabled="True"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBox
                            x:Name="KeychainContentBox"
                            AcceptsReturn="True"
                            Header="钥匙串内容"
                            Height="150"
                            TextWrapping="Wrap"
                            VerticalContentAlignment="Top" />

                        <Button Click="DecodeKeychainButton_Click" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D7;" />
                                <TextBlock x:Name="DecodeKeychainButtonText" Text="解析钥匙串内容" />
                            </StackPanel>
                        </Button>

                        <InfoBar
                            x:Name="MacResultInfo"
                            IsClosable="False"
                            IsOpen="False">
                            <TextBlock
                                x:Name="MacResultText"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap" />
                        </InfoBar>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>

        <Border
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock x:Name="ResultLabelText" FontWeight="SemiBold" Text="解析结果" />
                <TextBox
                    x:Name="ResultIrkBox"
                    IsReadOnly="True"
                    PlaceholderText="尚未解析出 IRK" />
                <TextBlock
                    x:Name="PrivacyText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="内容仅在本机解析，不会上传或保存。"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</ContentDialog>
